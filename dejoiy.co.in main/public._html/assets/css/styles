/* =================================
   RESPONSIVE BREAKPOINTS
================================= */

/* Large laptops */
@media (max-width: 1200px) {
  .container-premium {
    width: min(100% - 3rem, 1100px);
  }
}

/* Tablets */
@media (max-width: 992px) {

  h1 {
    font-size: 2.2rem;
  }

  h2 {
    font-size: 1.8rem;
  }

  .grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}

@media (max-width: 992px) {
  .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .grid {
    grid-template-columns: 1fr;
  }
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}

  .section {
    padding: 60px 20px;
  }

}

/* Mobile */
@media (max-width: 768px) {

  body {
    font-size: 15px;
  }

  h1 {
    font-size: 1.9rem;
  }

  h2 {
    font-size: 1.6rem;
  }

  h3 {
    font-size: 1.3rem;
  }

  .container-premium {
    width: calc(100% - 1.5rem);
  }

  .btn,
  button {
    width: 100%;
  }

}

/* Small phones */
@media (max-width: 480px) {

  h1 {
    font-size: 1.6rem;
  }

  h2 {
    font-size: 1.4rem;
  }

  .section {
    padding: 40px 16px;
  }

}
