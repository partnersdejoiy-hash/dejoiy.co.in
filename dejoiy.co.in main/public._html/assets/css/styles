.floating-orb {
  position: absolute;
  border-radius: 999px;
  filter: blur(30px);
  opacity: 0.65;
  animation: floatSlow 8s ease-in-out infinite;
}

.orb-blue {
  background: radial-gradient(circle, rgba(59, 130, 246, 0.8) 0%, rgba(59, 130, 246, 0.05) 65%, transparent 100%);
}

.orb-magenta {
  background: radial-gradient(circle, rgba(217, 70, 239, 0.7) 0%, rgba(217, 70, 239, 0.04) 65%, transparent 100%);
}

.orb-cyan {
  background: radial-gradient(circle, rgba(6, 182, 212, 0.7) 0%, rgba(6, 182, 212, 0.03) 65%, transparent 100%);
}

@keyframes floatSlow {
  0%, 100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(0, -18px, 0) scale(1.05);
  }
}

/* Base D frame */
.d-frame{
position: relative;
overflow: hidden;

/* D shape */
border-radius: 140px 28px 28px 140px;

background:#0f172a;
border:1px solid rgba(120,140,255,0.35);
box-shadow:0 0 18px rgba(120,140,255,0.18);
}

/* Decorative background shapes ONLY for team cards */
.d-frame-md::before,
.d-frame-md::after{
content:"";
position:absolute;
width:160%;
height:160%;
top:-30%;
left:-30%;
pointer-events:none;
z-index:0;
opacity:0.18;
}

/* First gradient D curve */
.d-frame-md::before{
background:linear-gradient(135deg,#4f46e5,#7c3aed,#06b6d4);
border-radius:320px 320px 40px 40px;
transform:rotate(-20deg);
}

/* Second softer curve */
.d-frame-md::after{
background:linear-gradient(135deg,#ec4899,#8b5cf6,#3b82f6);
border-radius:280px 280px 40px 40px;
transform:rotate(25deg);
opacity:0.12;
}

/* Default images (for marketplace, services etc.) */
.d-frame img{
width:100%;
height:100%;
object-fit:cover;
object-position:center;
display:block;
}

/* Team images only */
.d-frame-md img{
position:relative;
z-index:2;
object-fit:contain;
background:#0f172a;
}

/* Small cards */
.d-frame-sm{
height:180px;
}

/* Team card frame */
.d-frame-md{
height:820px;
overflow:hidden;
border-radius:260px 260px 28px 28px;
position:relative;
}

/* Founder frame */
.d-frame-lg{
width:420px;
height:520px;
margin:auto;
}

/* Founder portrait container */
.founder-frame{
width:clamp(260px, 28vw, 420px);
aspect-ratio:4/5;
overflow:hidden;
border-radius:28px;
margin:auto;
}

.founder-frame img{
width:100%;
height:100%;
object-fit:cover;
object-position:center;
}

/* Browser fallback */
@supports not (clip-path: path("M 0 0 L 10 10")) {
.d-frame{
clip-path:none;
border-radius:32px;
}
}

/* Scroll reveal animation */
.reveal{
opacity:0;
transform:translateY(24px);
transition:opacity 0.8s ease, transform 0.8s ease;
}

.reveal.active{
opacity:1;
transform:translateY(0);
}

/* Premium input styling */
.input-premium{
width:100%;
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.12);
color:white;
border-radius:18px;
padding:1rem;
outline:none;
transition:border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

.input-premium::placeholder{
color:#8ca0c0;
}

.input-premium:focus{
border-color:rgba(86,163,255,0.8);
box-shadow:0 0 0 4px rgba(59,130,246,0.15), 0 0 24px rgba(217,70,239,0.12);
background:rgba(255,255,255,0.07);
}

.footer-grid{
