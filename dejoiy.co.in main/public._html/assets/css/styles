:root {
  --bg-primary: #07111f;
  --bg-secondary: #0c1830;
  --panel: rgba(255, 255, 255, 0.06);
  --panel-border: rgba(255, 255, 255, 0.12);
  --text-primary: #f5f7fb;
  --text-secondary: #a7b3c9;
  --blue: #3b82f6;
  --royal: #4f46e5;
  --cyan: #06b6d4;
  --magenta: #d946ef;
  --gold: #f5c15d;
  --shadow-glow: 0 0 40px rgba(79, 70, 229, 0.25);
  --shadow-cyan: 0 0 40px rgba(6, 182, 212, 0.18);
  --radius-xl: 28px;
  --radius-2xl: 36px;
  --container: 1280px;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background:
    radial-gradient(circle at 20% 20%, rgba(59, 130, 246, 0.12), transparent 30%),
    radial-gradient(circle at 80% 30%, rgba(217, 70, 239, 0.10), transparent 25%),
    radial-gradient(circle at 50% 80%, rgba(6, 182, 212, 0.08), transparent 25%),
    linear-gradient(180deg, #050b16 0%, #081120 45%, #09162b 100%);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.05;
  background-image:
    url("data:image/svg+xml,%3Csvg width='180' height='180' viewBox='0 0 180 180' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M48 30H90C124 30 146 52 146 90C146 128 124 150 90 150H48V30ZM76 56V124H89C107 124 118 111 118 90C118 69 107 56 89 56H76Z' stroke='white' stroke-opacity='0.8' stroke-width='2'/%3E%3C/svg%3E");
  background-size: 180px 180px;
  background-repeat: repeat;
}

img{
max-width:100%;
height:auto;
display:block;
object-fit:cover;
object-position:center;
}

a {
  text-decoration: none;
  color: inherit;
}

button {
  font: inherit;
  cursor: pointer;
}

.container-premium {
  width: min(100% - 2rem, var(--container));
  margin-inline: auto;
}

.glass {
  background: var(--panel);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border: 1px solid var(--panel-border);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
}

.gradient-text {
  background: linear-gradient(90deg, #8ab4ff 0%, #7dd3fc 25%, #d946ef 75%, #f5c15d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-padding {
  padding: 96px 1rem;
}

.section-title {
  font-family: 'Poppins', sans-serif;
  font-size: clamp(2rem, 4vw, 4rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  color: var(--text-primary);
}

.section-subtitle {
  color: var(--text-secondary);
  font-size: 1.05rem;
  line-height: 1.8;
  max-width: 720px;
}

.page-hero{
display:flex;
align-items:center;
justify-content:center;
min-height:70vh;
}

.page-hero img{
width:clamp(280px, 35vw, 520px);
height:auto;
object-fit:contain;
object-position:center;
display:block;
margin:auto;
padding:14%;
}

.text-muted {
  color: var(--text-secondary);
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border-radius: 999px;
  padding: 0.45rem 0.8rem;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #dbe6ff;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.premium-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  background: var(--bg-secondary);
  padding: 1.5rem;
}

.premium-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-glow), 0 18px 40px rgba(29, 29, 41, 0.85);
}

.glow-border {
  position: relative;
}

.glow-border::before {
  content: "";
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.8), rgba(217, 70, 239, 0.7), rgba(6, 182, 212, 0.75));
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.8;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  padding: 0.95rem 1.35rem;
  border-radius: 999px;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 45%, #d946ef 100%);
  box-shadow: 0 8px 24px rgba(96, 80, 255, 0.35);
  transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
  white-space: nowrap;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 30px rgba(96, 80, 255, 0.45);
  filter: brightness(1.1);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  padding: 0.95rem 1.35rem;
  border-radius: 999px;
  font-weight: 600;
  color: #e8eefc;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.04);
  transition: all 0.25s ease;
  white-space: nowrap;
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.09);
  transform: translateY(-2px);
}

.nav-blur {
  background: rgba(7, 17, 31, 0.72);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.nav-link {
  color: #d4def3;
  transition: color 0.25s ease;
  font-weight: 500;
}

.nav-link:hover {
  color: white;
}

.mobile-menu {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.mobile-menu.open {
  max-height: 600px;
}

