{
  "buildCommand": "mkdir -p public && cp -r 'dejoiy.co.in main/public/.' public/",
  "outputDirectory": "public",
  "framework": null,
  "routes": [
    { "src": "/about",    "dest": "/about.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/team",     "dest": "/team.html" },
    { "src": "/contact",  "dest": "/contact.html" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
